# BLING Blue Team — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# PostgreSQL
POSTGRES_URL=postgresql://bling_user:changeme@localhost:5432/bling_blue
POSTGRES_USER=bling_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bling_blue

# Neo4j (teammate's Graph Engine service — read-only)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6379

# API Keys (generate with: python -c "import secrets; print(secrets.token_hex(32))")
GRAPH_ENGINE_API_KEY=changeme-graph-engine-key
INVESTIGATOR_API_KEY=changeme-investigator-key
INTERNAL_API_KEY=changeme-internal-key-never-use-in-prod

# Integration endpoints (teammates' services)
BLOCKCHAIN_SERVICE_URL=http://localhost:8001
RED_TEAM_SERVICE_URL=http://localhost:8002
INVESTIGATOR_DASHBOARD_URL=http://localhost:8003

# PII pseudonymization salt (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SALT=changeme-salt-value

# Model
MODEL_VERSION=v1.0

# Scoring thresholds (can tune without code change)
THRESHOLD_LOG=0.38
THRESHOLD_REVIEW=0.62
THRESHOLD_HIGH_RISK=0.83

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# App
DEBUG=false
LOG_LEVEL=INFO
