# Never copy these into the Docker image

# Version control
.git/
.gitignore

# Environment secrets
.env
.env.*
!.env.example

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
*.egg-info/

# Tests — not needed in production image
tests/
test_dna/

# Dev docs and planning
agent_docs/
docs/
.claude/
PENDING.md

# ML data and trained models — mounted as volume at runtime
ml/data/
ml/models/

# OS
.DS_Store
*.log

# Local scripts (not part of production app)
scripts/

# Build artifacts
dist/
build/
